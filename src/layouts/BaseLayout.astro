---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  type?: 'website' | 'article';
}

const { title, description, ogImage, type } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <SEOHead title={title} description={description} ogImage={ogImage} type={type} />
  </head>
  <body class="bg-white text-green-950 font-sans antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-green-700 text-white px-4 py-2 rounded z-50">
      Skip to content
    </a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
