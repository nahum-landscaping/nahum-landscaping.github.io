---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABanner from '../components/CTABanner.astro';
import { siteConfig } from '../config';
---

<BaseLayout
  title="About Us"
  description="Learn about Nahum J Landscaping LLC — a locally owned and operated landscaping company serving Sanford, FL. Licensed, insured, and committed to quality yard care."
>
  <!-- Page Header -->
  <section class="bg-green-900 py-16 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4">
        About Nahum J Landscaping
      </h1>
      <p class="text-green-100 text-xl max-w-3xl mx-auto">
        Locally owned. Community focused. Dedicated to making Sanford beautiful, one yard at a time.
      </p>
    </div>
  </section>

  <!-- Owner Story -->
  <section class="py-16 sm:py-20" aria-labelledby="story-heading">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <!-- TODO: Replace with actual owner/team photo -->
        <div class="rounded-xl overflow-hidden shadow-lg">
          <img
            src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=800&q=80"
            alt="Nahum J Landscaping team at work in Sanford, Florida"
            class="w-full h-96 object-cover"
            loading="lazy"
            width="800"
            height="600"
          />
        </div>
        <div>
          <h2 id="story-heading" class="text-3xl font-bold text-green-900 mb-6">Our Story</h2>
          <!-- TODO: Replace with actual company story -->
          <div class="space-y-4 text-gray-600 leading-relaxed">
            <p>
              Nahum J Landscaping LLC was founded with a simple mission: provide honest, high-quality
              landscaping services to the Sanford, Florida community at fair prices. What started as
              a one-person operation has grown into a trusted local landscaping company serving
              homeowners and businesses throughout the area.
            </p>
            <p>
              As a locally owned and operated business, we understand the unique challenges of
              maintaining beautiful landscapes in Central Florida. From the summer heat and afternoon
              thunderstorms to hurricane season preparation, we know what it takes to keep your
              property looking its best year-round.
            </p>
            <p>
              Every member of our team shares a passion for the outdoors and a commitment to
              craftsmanship. We treat every property — whether a small residential lawn or a large
              commercial site — with the same care and attention to detail.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-16 sm:py-20 bg-sand-50" aria-labelledby="values-heading">
    <div class="max-w-7xl mx-auto px-4">
      <h2 id="values-heading" class="text-3xl font-bold text-green-900 text-center mb-12">
        What We Stand For
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-green-800 mb-2">Quality Workmanship</h3>
          <p class="text-gray-600 text-sm">We take pride in every cut, every trim, and every installation. No shortcuts, no half-measures.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-green-800 mb-2">Reliability</h3>
          <p class="text-gray-600 text-sm">We show up on time, every time. Your schedule matters, and so does your trust in us.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-green-800 mb-2">Community First</h3>
          <p class="text-gray-600 text-sm">We live and work in Sanford. This community is our home, and we're invested in making it beautiful.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-green-800 mb-2">Honest Pricing</h3>
          <p class="text-gray-600 text-sm">Transparent quotes with no hidden fees. You know exactly what you're paying for before work begins.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-green-800 mb-2">Eco-Conscious</h3>
          <p class="text-gray-600 text-sm">We prioritize sustainable practices, native plants, and water-efficient solutions for Florida landscapes.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="h-6 w-6 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-green-800 mb-2">Licensed & Insured</h3>
          <p class="text-gray-600 text-sm">Fully licensed and insured for your protection. We carry liability insurance and workers' compensation.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="py-16 sm:py-20" aria-labelledby="area-heading">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 id="area-heading" class="text-3xl font-bold text-green-900 mb-6">
        Proudly Serving Sanford, FL
      </h2>
      <p class="text-gray-600 text-lg mb-8 leading-relaxed">
        We provide landscaping services throughout Sanford, Florida and the surrounding communities
        including Lake Mary, Longwood, Winter Springs, and other areas of Seminole County.
        Whether you're in a historic downtown neighborhood or a newer development, we're just a
        phone call away.
      </p>
      <a
        href={siteConfig.phoneHref}
        class="inline-flex items-center gap-2 text-green-700 hover:text-green-800 font-semibold text-lg"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        Call us at {siteConfig.phone}
      </a>
    </div>
  </section>

  <CTABanner />
</BaseLayout>
