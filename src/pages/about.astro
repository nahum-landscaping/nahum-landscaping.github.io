---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABanner from '../components/CTABanner.astro';
import { PageHeader, Section, PhoneButton } from '../components/ui';
---

<BaseLayout
  title="About Us"
  description="Nahum J Landscaping LLC. A locally owned lawn care and landscaping business serving Sanford, FL. Licensed, insured, and straightforward."
>
  <PageHeader
    title="About Us"
    subtitle="A small, locally owned lawn care business based in Sanford, FL."
    bgImage="/images/360_F_724631497_FzznfnmeuP6WIXfM6uuQtPY4fCDL73mr.jpg"
  />

  <!-- Owner Story -->
  <Section aria-labelledby="story-heading">
    <div class="flex flex-col-reverse md:grid md:grid-cols-2 gap-10 items-center fade-up">
      <!-- TODO: Replace with actual photo of Nahum/crew — use a real owner or team photo here -->
      <div class="rounded-xl overflow-hidden shadow-lg">
        <img
          src="/images/residential-home.jpg"
          alt="Residential home with a well-maintained yard in Sanford, Florida"
          class="w-full max-h-[250px] md:max-h-none md:h-96 object-cover"
          loading="lazy"
          width="800"
          height="600"
        />
      </div>
      <div>
        <h2 id="story-heading" class="text-3xl font-bold text-green-900 mb-4">Who We Are</h2>
        <!-- TODO: Replace with actual company story from Nahum -->
        <div class="space-y-4 text-gray-600 leading-relaxed">
          <p>
            Nahum J Landscaping is a two-person operation based right here in Sanford, Florida.
            We handle lawn care and landscaping for residential properties in the area,
            and we do it all ourselves.
          </p>
          <p>
            We started this business because we enjoy the work and we're good at it. No corporate
            office, no call center. When you call, you're talking to the person who's going to
            be working on your yard.
          </p>
          <p>
            Right now we maintain over 175 yards on a regular schedule. Most of our customers
            came to us through referrals from their neighbors, and that's something we don't
            take for granted.
          </p>
        </div>
      </div>
    </div>
  </Section>

  <!-- What We're About -->
  <Section bg="sand" aria-labelledby="about-heading">
    <div class="max-w-3xl mx-auto fade-up">
      <h2 id="about-heading" class="text-3xl sm:text-4xl font-bold text-green-900 mb-6 text-center">What We're About</h2>
      <!-- TODO: Replace with actual personal story from Nahum -->
      <div class="space-y-4 text-gray-600 leading-relaxed text-center">
        <p>
          We grew up in Sanford. This is where we live, where our families are, and where we
          want to build something that lasts. Starting a landscaping business wasn't a corporate
          decision. It was a simple one: we're good at this work, we like doing it, and we
          wanted to do it for our own community.
        </p>
        <p>
          Every yard we take care of is in a neighborhood we drive through every day. That
          matters to us. We're not trying to be the biggest company in Central Florida. We
          just want to do good work for the people around us and earn their trust one yard
          at a time.
        </p>
      </div>
    </div>
  </Section>

  <!-- Service Area -->
  <Section aria-labelledby="area-heading">
    <div class="max-w-4xl mx-auto text-center fade-up">
      <h2 id="area-heading" class="text-3xl font-bold text-green-900 mb-4">
        Proudly Serving Sanford, FL
      </h2>
      <p class="text-gray-600 text-lg mb-8 leading-relaxed">
        We serve residential properties in Sanford, FL. If you're in the area, give us a call.
      </p>
      <PhoneButton variant="ghost" />
    </div>
  </Section>

  <CTABanner />
</BaseLayout>
