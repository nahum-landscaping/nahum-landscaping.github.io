---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABanner from '../components/CTABanner.astro';
import { siteConfig } from '../config';
import { PageHeader, Section, IconCard, PhoneButton } from '../components/ui';

const values = [
  {
    title: 'Show Up, Every Time',
    description: 'If we say we\'ll be there Thursday, we\'re there Thursday. Consistency matters.',
    icon: '<svg class="h-6 w-6 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>',
  },
  {
    title: 'Honest Pricing',
    description: 'You\'ll know what the job costs before we start. We don\'t tack on extras or surprise you with a bigger bill.',
    icon: '<svg class="h-6 w-6 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>',
  },
  {
    title: 'We Live Here Too',
    description: 'We\'re based in Sanford. This is our community, and we take pride in how it looks.',
    icon: '<svg class="h-6 w-6 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>',
  },
  {
    title: 'Licensed & Insured',
    description: 'Fully licensed with liability insurance and workers\' comp. Your property is covered.',
    icon: '<svg class="h-6 w-6 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>',
  },
];
---

<BaseLayout
  title="About Us"
  description="Nahum J Landscaping LLC — a locally owned lawn care and landscaping business serving Sanford, FL. Licensed, insured, and straightforward."
>
  <PageHeader
    title="About Nahum J Landscaping"
    subtitle="A small, locally owned lawn care business based in Sanford, FL."
  />

  <!-- Owner Story -->
  <Section aria-labelledby="story-heading">
    <div class="grid md:grid-cols-2 gap-10 items-center fade-up">
      <!-- TODO: Replace with actual photo of Nahum working -->
      <div class="rounded-xl overflow-hidden shadow-lg">
        <img
          src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=800&q=80"
          alt="Residential home with a well-maintained lawn in Central Florida"
          class="w-full h-96 object-cover"
          loading="lazy"
          width="800"
          height="600"
        />
      </div>
      <div>
        <h2 id="story-heading" class="text-3xl font-bold text-green-900 mb-4">Who We Are</h2>
        <!-- TODO: Replace with actual company story from Nahum -->
        <div class="space-y-4 text-gray-600 leading-relaxed">
          <p>
            Nahum J Landscaping is a two-person operation based right here in Sanford, Florida.
            We handle lawn care and landscaping for residential properties across the area —
            and we do it all ourselves.
          </p>
          <p>
            We started this business because we enjoy the work and we're good at it. No corporate
            office, no call center. When you call, you're talking to the person who's going to
            be working on your yard.
          </p>
          <p>
            Right now we maintain over 175 yards on a regular schedule. Most of our customers
            came to us through referrals from their neighbors, and that's something we don't
            take for granted.
          </p>
        </div>
      </div>
    </div>
  </Section>

  <!-- Values -->
  <Section bg="sand" aria-labelledby="values-heading">
    <h2 id="values-heading" class="text-3xl sm:text-4xl font-bold text-green-900 mb-4 text-center">How We Work</h2>
    <p class="text-gray-600 text-lg text-center max-w-2xl mx-auto mb-10">Simple approach, consistent results.</p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 stagger-children">
      {values.map((v) => (
        <IconCard title={v.title} description={v.description} icon={v.icon} />
      ))}
    </div>
  </Section>

  <!-- Service Area -->
  <Section aria-labelledby="area-heading">
    <div class="max-w-4xl mx-auto text-center fade-up">
      <h2 id="area-heading" class="text-3xl font-bold text-green-900 mb-4">
        Serving Sanford & Seminole County
      </h2>
      <p class="text-gray-600 text-lg mb-8 leading-relaxed">
        We work throughout Sanford, Lake Mary, Longwood, Winter Springs, and surrounding
        areas in Seminole County. If you're nearby, we can probably help.
      </p>
      <PhoneButton variant="ghost" />
    </div>
  </Section>

  <CTABanner />
</BaseLayout>
