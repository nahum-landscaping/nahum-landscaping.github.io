---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABanner from '../components/CTABanner.astro';
import { PageHeader, Section, Button, CheckList } from '../components/ui';

const services = [
  {
    id: 'lawn-care',
    title: 'Lawn Care & Maintenance',
    description: 'We handle the regular upkeep so your lawn stays healthy and looks good — week after week. We work with all common Florida grass types including St. Augustine, Bermuda, Zoysia, and Bahia.',
    details: [
      'Weekly or bi-weekly mowing',
      'Edging along sidewalks, driveways, and beds',
      'String trimming around fences and obstacles',
      'Blowing and cleanup after every visit',
      'Weed management in lawn areas',
    ],
    image: '/images/daniel-watson-8vBpYpTGo90-unsplash.jpg',
    imageAlt: 'Freshly mowed and edged residential lawn in Sanford, Florida',
  },
  {
    id: 'landscaping',
    title: 'Landscaping & Design',
    description: 'From new plantings to full bed renovations, we design and install landscapes that work for Central Florida\'s climate. We focus on plants that actually thrive here — not just what looks good at the nursery.',
    details: [
      'Custom planting layouts for your property',
      'Florida-native and tropical plant selection',
      'Flower bed installation and renovation',
      'Shrub and hedge planting',
      'Seasonal color rotations',
    ],
    image: '/images/360_F_724631497_FzznfnmeuP6WIXfM6uuQtPY4fCDL73mr.jpg',
    imageAlt: 'Tropical landscape with palms and colorful flowering plants',
  },
  {
    id: 'mulching',
    title: 'Mulching & Bed Maintenance',
    description: 'Mulch protects your plants, holds moisture in the Florida heat, and keeps beds looking clean. We handle the full job — weed removal, edging, and fresh mulch laid down right.',
    details: [
      'Premium hardwood and pine bark mulch',
      'Bed edging and shaping',
      'Weed removal and prevention',
      'Soil amendment when needed',
      'Seasonal flower planting',
    ],
    image: '/images/mulching-garden-beds.webp',
    imageAlt: 'Well-maintained landscape bed with fresh mulch and plants',
  },
  {
    id: 'hedge-trimming',
    title: 'Hedge & Shrub Trimming',
    description: 'Overgrown hedges make a property look neglected fast. We keep shrubs, hedges, and ornamental plants shaped and healthy with regular trimming.',
    details: [
      'Hedge shaping and maintenance',
      'Ornamental shrub pruning',
      'Overgrowth cleanup and restoration',
      'Post-storm cleanup and trimming',
      'Palm frond removal',
    ],
    image: '/images/Shearing-Plants-In-The-Garden-1000x667.jpg',
    imageAlt: 'Neatly trimmed hedges and maintained shrubs along a walkway',
  },
];
---

<BaseLayout
  title="Services"
  description="Lawn care and landscaping services in Sanford, FL — mowing, edging, landscaping, mulching, and hedge trimming. Free estimates from a locally owned business."
>
  <PageHeader
    title="Our Services"
    subtitle="Lawn care and landscaping for residential properties in Sanford, FL."
    bgImage="/images/daniel-watson-8vBpYpTGo90-unsplash.jpg"
  />

  <!-- Services List -->
  <Section>
    <div class="divide-y divide-gray-200 md:divide-y-0 md:space-y-12">
      {services.map((service, i) => (
        <article id={service.id} class="scroll-mt-24 fade-up py-10 first:pt-0 md:py-0">
          <div class:list={['flex flex-col-reverse md:grid md:grid-cols-2 gap-6 md:gap-8 items-center', i % 2 === 1 && 'md:[direction:rtl]']}>
            <div class={i % 2 === 1 ? 'md:[direction:ltr]' : ''}>
              <!-- TODO: Replace stock images with actual project photos -->
              <img
                src={service.image}
                alt={service.imageAlt}
                class="shadow-md w-full max-h-[250px] md:max-h-none md:h-80 object-cover mt-6 md:mt-0"
                loading="lazy"
                width="600"
                height="400"
              />
            </div>
            <div class={i % 2 === 1 ? 'md:[direction:ltr]' : ''}>
              <h2 class="text-2xl sm:text-3xl font-bold text-green-900 mb-3">{service.title}</h2>
              <p class="text-gray-600 mb-4 leading-relaxed">{service.description}</p>
              <CheckList items={service.details} />
            </div>
          </div>
        </article>
      ))}
    </div>
  </Section>

  <!-- FAQ Section -->
  <Section bg="sand" aria-labelledby="faq-heading">
    <div class="max-w-3xl mx-auto fade-up">
      <h2 id="faq-heading" class="text-3xl sm:text-4xl font-bold text-green-900 mb-8 md:text-center">Frequently Asked Questions</h2>
      <div>
        {[
          { q: 'How much does lawn care cost in Sanford?', a: 'It depends on the size of your yard and what you need done. Most of our weekly mowing customers pay between $20 and $40 per visit. We\'ll give you an exact quote after seeing your property.' },
          { q: 'How often should I mow my lawn in Florida?', a: 'During the growing season (spring through fall), most Florida lawns need mowing once a week. In winter, every two weeks is usually enough. We\'ll adjust the schedule based on how your grass is growing.' },
          { q: 'Do you offer one-time cleanups?', a: 'Yes. If you need a one-time cleanup, bed renovation, or your yard just needs to get back in shape, we can help. Just reach out and we\'ll come take a look.' },
          { q: 'What areas do you serve?', a: 'We currently serve residential properties in Sanford, FL.' },
          { q: 'Are you licensed and insured?', a: 'Yes. We carry full liability insurance and workers\' compensation coverage. We\'re happy to provide proof of insurance if needed.' },
          { q: 'How do I get a free estimate?', a: 'Call or text us, or fill out the form on our contact page. We\'ll come out to your property, walk it with you, and give you an honest price on the spot.' },
        ].map((faq) => (
          <div class="faq-item border-b border-gray-200">
            <button type="button" class="faq-trigger flex items-center justify-between w-full cursor-pointer py-5 text-green-900 font-semibold text-sm sm:text-base text-left" aria-expanded="false">
              {faq.q}
              <svg class="faq-chevron w-5 h-5 text-green-700 shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="faq-content">
              <div class="pb-5 text-gray-600 text-sm leading-relaxed">{faq.a}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- FAQ Schema Markup -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does lawn care cost in Sanford?", "acceptedAnswer": { "@type": "Answer", "text": "It depends on the size of your yard and what you need done. Most of our weekly mowing customers pay between $20 and $40 per visit. We'll give you an exact quote after seeing your property." }},
      { "@type": "Question", "name": "How often should I mow my lawn in Florida?", "acceptedAnswer": { "@type": "Answer", "text": "During the growing season (spring through fall), most Florida lawns need mowing once a week. In winter, every two weeks is usually enough." }},
      { "@type": "Question", "name": "Do you offer one-time cleanups?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. If you need a one-time cleanup, bed renovation, or your yard just needs to get back in shape, we can help." }},
      { "@type": "Question", "name": "What areas do you serve?", "acceptedAnswer": { "@type": "Answer", "text": "We currently serve residential properties in Sanford, FL." }},
      { "@type": "Question", "name": "Are you licensed and insured?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We carry full liability insurance and workers' compensation coverage." }},
      { "@type": "Question", "name": "How do I get a free estimate?", "acceptedAnswer": { "@type": "Answer", "text": "Call or text us, or fill out the form on our contact page. We'll come out to your property and give you an honest price on the spot." }},
    ]
  })} />

  <CTABanner
    heading="Want to talk about your yard?"
    text="Give us a call or send a message. We'll come take a look and let you know what we can do."
  />
</BaseLayout>

<script>
  const allFaqs = document.querySelectorAll('.faq-item');

  function closeItem(item: Element) {
    const content = item.querySelector('.faq-content') as HTMLElement;
    const trigger = item.querySelector('.faq-trigger') as HTMLElement;
    content.style.height = content.scrollHeight + 'px';
    requestAnimationFrame(() => {
      content.style.height = '0';
      content.style.opacity = '0';
    });
    item.classList.remove('is-open');
    trigger.setAttribute('aria-expanded', 'false');
  }

  function openItem(item: Element) {
    const content = item.querySelector('.faq-content') as HTMLElement;
    const inner = content.firstElementChild as HTMLElement;
    const trigger = item.querySelector('.faq-trigger') as HTMLElement;
    const h = inner.offsetHeight;
    content.style.height = '0';
    content.style.opacity = '0';
    item.classList.add('is-open');
    trigger.setAttribute('aria-expanded', 'true');
    requestAnimationFrame(() => {
      content.style.height = h + 'px';
      content.style.opacity = '1';
    });
    setTimeout(() => { content.style.height = 'auto'; }, 250);
  }

  allFaqs.forEach((item) => {
    item.querySelector('.faq-trigger')!.addEventListener('click', () => {
      const isOpen = item.classList.contains('is-open');
      // Close all others
      allFaqs.forEach((other) => {
        if (other !== item && other.classList.contains('is-open')) closeItem(other);
      });
      // Toggle this one
      if (isOpen) { closeItem(item); } else { openItem(item); }
    });
  });
</script>
