---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABanner from '../components/CTABanner.astro';
import { PageHeader, Section, Badge } from '../components/ui';

// TODO: Replace ALL placeholder images with actual project photos
const projects = [
  { src: '/images/daniel-watson-8vBpYpTGo90-unsplash.jpg', alt: 'Lush green lawn with clean edging in Sanford, FL', category: 'Lawn Care' },
  { src: '/images/Grass-Cutting-Lawrenceville-GA.jpg', alt: 'Freshly cut residential lawn with clean lines', category: 'Lawn Care' },
  { src: '/images/360_F_724631497_FzznfnmeuP6WIXfM6uuQtPY4fCDL73mr.jpg', alt: 'Tropical landscape design with flowering plants', category: 'Landscaping' },
  { src: '/images/360_F_85781068_MwcreyRycIzpDLVtm311btoFYikWURph.jpg', alt: 'Maintained front yard with green grass and shrubs', category: 'Lawn Care' },
  { src: '/images/mulching-garden-beds.webp', alt: 'Garden bed with fresh mulch and healthy plants', category: 'Mulching' },
  { src: '/images/gardener-mulching-pine-bark-juniper-plants-yard-seasonal-works-garden-landscape-design-ornamental-shrub-186896913.webp', alt: 'Mulching around ornamental shrubs and juniper plants', category: 'Mulching' },
  { src: '/images/bush-1024x682.jpg', alt: 'Neatly trimmed bushes and hedges along property line', category: 'Landscaping' },
  { src: '/images/Shearing-Plants-In-The-Garden-1000x667.jpg', alt: 'Hedge trimming and shaping in a residential garden', category: 'Landscaping' },
  { src: '/images/360_F_334200452_zW4J8ij36GPGsxB4uNDuxynRmpohn3jd.jpg', alt: 'Well-maintained residential lawn and landscaping', category: 'Lawn Care' },
];

const categories = ['All', 'Lawn Care', 'Landscaping', 'Mulching'];
---

<BaseLayout
  title="Gallery"
  description="See our lawn care and landscaping work in Sanford, FL. Browse photos of maintained lawns, landscaping projects, and more."
>
  <PageHeader
    title="Our Work"
    subtitle="Recent work around Sanford, FL."
    bgImage="/images/tropical-landscape.jpg"
  />

  <Section aria-labelledby="gallery-heading">
    <h2 id="gallery-heading" class="sr-only">Project Gallery</h2>

    <!-- Category Filter Tabs -->
    <div class="flex gap-2 mb-8 overflow-x-auto scrollbar-hide" role="tablist" aria-label="Filter by category">
      {categories.map((cat) => (
        <button
          type="button"
          role="tab"
          class="gallery-filter px-3.5 py-1.5 sm:px-5 sm:py-2.5 rounded-full text-sm font-medium transition-all duration-200 whitespace-nowrap shrink-0"
          data-category={cat}
          aria-selected={cat === 'All' ? 'true' : 'false'}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- TODO: Replace placeholder images with actual project photos -->
    <div id="gallery-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <figure class="gallery-item group rounded-xl overflow-hidden shadow-sm card-hover fade-up" data-category={project.category}>
          <div class="relative overflow-hidden">
            <img
              src={project.src}
              alt={project.alt}
              class="w-full h-64 object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
              width="600"
              height="400"
            />
            <div class="absolute top-3 left-3">
              <Badge text={project.category} />
            </div>
          </div>
          <figcaption class="p-4 bg-white">
            <p class="text-sm text-gray-600">{project.alt}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </Section>

  <CTABanner
    heading="Like what you see?"
    text="Give us a call and we'll come take a look at your property. Free estimates, always."
  />
</BaseLayout>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .gallery-filter {
    background: transparent;
    color: #15803d;
    border: 1.5px solid #e8dcc8;
    cursor: pointer;
  }
  .gallery-filter:hover {
    background: #f0fdf4;
    border-color: #15803d;
  }
  .gallery-filter[aria-selected="true"] {
    background: #15803d;
    color: white;
    border-color: #15803d;
  }
  .gallery-item {
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .gallery-item.hidden-item {
    display: none;
  }
</style>

<script>
  const buttons = document.querySelectorAll('.gallery-filter');
  const items = document.querySelectorAll('.gallery-item');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category');

      // Update active tab
      buttons.forEach((b) => b.setAttribute('aria-selected', 'false'));
      btn.setAttribute('aria-selected', 'true');

      // Filter items
      items.forEach((item) => {
        if (category === 'All' || item.getAttribute('data-category') === category) {
          item.classList.remove('hidden-item');
        } else {
          item.classList.add('hidden-item');
        }
      });
    });
  });
</script>
