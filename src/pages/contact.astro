---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config';
import { PageHeader, Section, Button } from '../components/ui';
---

<BaseLayout
  title="Contact Us"
  description="Contact Nahum J Landscaping for a free lawn care estimate in Sanford, FL. Call us or fill out our form. Licensed & insured."
>
  <PageHeader
    title="Get a Free Estimate"
    subtitle="Send us a message or give us a call. We'll come take a look at your property and give you an honest estimate."
    bgImage="/images/360_F_85781068_MwcreyRycIzpDLVtm311btoFYikWURph.jpg"
  />

  <Section>
    <div class="grid md:grid-cols-2 gap-10">
      <!-- Contact Form -->
      <div class="fade-up">
        <h2 class="text-2xl font-bold text-green-900 mb-6">Send Us a Message</h2>

        <!-- Success State -->
        <div id="form-success" class="hidden bg-green-50 border border-green-200 rounded-xl p-8 text-center">
          <svg class="w-12 h-12 text-green-600 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <h3 class="text-xl font-bold text-green-900 mb-2">Message Sent</h3>
          <p class="text-gray-600">Thanks! We'll get back to you as soon as we can.</p>
        </div>

        <!-- TODO: Replace YOUR_FORM_ID in config.ts with actual Formspree endpoint -->
        <form id="contact-form" action={siteConfig.formspreeEndpoint} method="POST" class="space-y-5" novalidate>
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Full Name *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              class="form-input w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors"
              placeholder="Your name"
            />
            <p class="form-error hidden text-red-600 text-xs mt-1">Please enter your name.</p>
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              class="form-input w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors"
              placeholder="your@email.com"
            />
            <p class="form-error hidden text-red-600 text-xs mt-1">Please enter a valid email address.</p>
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              autocomplete="tel"
              class="form-input w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors"
              placeholder="(786) 614-2874"
            />
          </div>
          <div>
            <label for="service" class="block text-sm font-medium text-gray-700 mb-1">Service Interested In</label>
            <select
              id="service"
              name="service"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors bg-white"
            >
              <option value="">Select a service...</option>
              <option value="Lawn Care">Lawn Care & Mowing</option>
              <option value="Landscaping">Landscaping & Design</option>
              <option value="Mulching">Mulching & Bed Care</option>
              <option value="Hedge Trimming">Hedge & Shrub Trimming</option>
              <option value="Other">Something Else</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message *</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="form-input w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-colors resize-y"
              placeholder="Tell us a bit about your yard and what you're looking for..."
            ></textarea>
            <p class="form-error hidden text-red-600 text-xs mt-1">Please enter a message.</p>
          </div>
          <!-- Formspree honeypot for spam protection -->
          <input type="text" name="_gotcha" class="hidden" />
          <Button type="submit" fullWidth size="lg">Send Message</Button>
          <p class="text-xs text-gray-500 text-center">
            We'll get back to you as soon as we can.
          </p>
        </form>
      </div>

      <!-- Contact Info Sidebar -->
      <div class="space-y-8 fade-up">
        <!-- Phone -->
        <div class="bg-sand-50 rounded-xl p-6">
          <h3 class="text-lg font-bold text-green-800 mb-4">Prefer to Call?</h3>
          <!-- TODO: Replace placeholder phone number with actual number -->
          <a
            href={siteConfig.phoneHref}
            aria-label={`Call Nahum J Landscaping at ${siteConfig.phone}`}
            class="text-2xl font-bold text-green-700 hover:text-green-800 transition-colors"
          >
            {siteConfig.phone}
          </a>
          <p class="text-gray-600 text-sm mt-2">Call or text anytime. It's the fastest way to reach us.</p>
        </div>

        <!-- Hours -->
        <div class="bg-sand-50 rounded-xl p-6">
          <h3 class="text-lg font-bold text-green-800 mb-4">Business Hours</h3>
          <ul class="space-y-2 text-sm text-gray-600">
            <li class="flex justify-between">
              <span>Monday - Sunday</span>
              <span class="font-medium text-gray-800">7:00 AM - 6:00 PM</span>
            </li>
          </ul>
          <p class="text-xs text-gray-400 mt-3">Hours may vary. Call or text to confirm availability.</p>
        </div>

        <!-- Email -->
        <div class="bg-sand-50 rounded-xl p-6">
          <h3 class="text-lg font-bold text-green-800 mb-4">Email Us</h3>
          <!-- TODO: Replace placeholder email with actual email address -->
          <a
            href={`mailto:${siteConfig.email}`}
            class="text-green-700 hover:text-green-800 font-medium transition-colors"
          >
            {siteConfig.email}
          </a>
        </div>

        <!-- Service Area -->
        <div class="bg-sand-50 rounded-xl p-6">
          <h3 class="text-lg font-bold text-green-800 mb-4">Service Area</h3>
          <p class="text-gray-600 text-sm">Currently serving Sanford, FL</p>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Clear previous errors
    form.querySelectorAll('.form-input').forEach((el) => el.classList.remove('!border-red-500'));
    form.querySelectorAll('.form-error').forEach((el) => el.classList.add('hidden'));

    // Validate required fields
    let valid = true;
    const fields = [
      { id: 'name', check: (v: string) => v.trim().length > 0 },
      { id: 'email', check: (v: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v) },
      { id: 'message', check: (v: string) => v.trim().length > 0 },
    ];

    fields.forEach(({ id, check }) => {
      const input = form.querySelector(`#${id}`) as HTMLInputElement | HTMLTextAreaElement;
      if (input && !check(input.value)) {
        valid = false;
        input.classList.add('!border-red-500');
        const error = input.parentElement?.querySelector('.form-error');
        error?.classList.remove('hidden');
      }
    });

    if (!valid) return;

    // Submit via fetch
    const data = new FormData(form);
    try {
      await fetch(form.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
      form.classList.add('hidden');
      success?.classList.remove('hidden');
    } catch {
      form.classList.add('hidden');
      success?.classList.remove('hidden');
    }
  });

  // Clear error on input
  form?.querySelectorAll('.form-input').forEach((input) => {
    input.addEventListener('input', () => {
      input.classList.remove('!border-red-500');
      input.parentElement?.querySelector('.form-error')?.classList.add('hidden');
    });
  });
</script>
