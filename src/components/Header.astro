---
import { siteConfig } from '../config';

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services/', label: 'Services' },
  { href: '/about/', label: 'About' },
  { href: '/gallery/', label: 'Gallery' },
  { href: '/contact/', label: 'Contact' },
];
---

<!-- Top Bar -->
<div class="bg-green-900 text-white text-sm py-2">
  <div class="max-w-7xl mx-auto px-4 flex flex-wrap justify-between items-center gap-2">
    <span class="flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
      Serving {siteConfig.serviceArea}
    </span>
    <div class="flex items-center gap-4">
      <span class="hidden sm:inline">Licensed & Insured</span>
      <a href={siteConfig.phoneHref} class="font-semibold hover:text-green-300 transition-colors flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        {siteConfig.phone}
      </a>
    </div>
  </div>
</div>

<!-- Main Navigation -->
<header class="bg-white shadow-sm sticky top-0 z-40">
  <nav class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between" aria-label="Main navigation">
    <a href="/" class="text-xl sm:text-2xl font-bold text-green-800 hover:text-green-700 transition-colors">
      Nahum J Landscaping
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'text-sm font-medium transition-colors hover:text-green-600',
            currentPath === link.href ? 'text-green-700 border-b-2 border-green-600' : 'text-green-900',
          ]}
          aria-current={currentPath === link.href ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
      <a
        href="/contact/"
        class="bg-green-700 hover:bg-green-800 text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition-colors"
      >
        Get a Free Quote
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-green-800"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t px-4 pb-4" role="navigation" aria-label="Mobile navigation">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class:list={[
          'block py-3 text-sm font-medium border-b border-gray-100 transition-colors',
          currentPath === link.href ? 'text-green-700' : 'text-green-900 hover:text-green-600',
        ]}
        aria-current={currentPath === link.href ? 'page' : undefined}
      >
        {link.label}
      </a>
    ))}
    <a
      href="/contact/"
      class="block mt-3 bg-green-700 hover:bg-green-800 text-white px-5 py-3 rounded-lg text-sm font-semibold text-center transition-colors"
    >
      Get a Free Quote
    </a>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
