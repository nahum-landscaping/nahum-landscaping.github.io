---
import { siteConfig } from '../config';
import { Button } from './ui';

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services/', label: 'Services' },
  { href: '/about/', label: 'About' },
  { href: '/gallery/', label: 'Gallery' },
  { href: '/contact/', label: 'Contact' },
];
---

<!-- Main Navigation -->
<header class="bg-white shadow-sm sticky top-0 z-40">
  <nav class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between" aria-label="Main navigation">
    <a href="/" class="text-xl sm:text-2xl font-bold text-green-800 hover:text-green-700 transition-colors">
      Nahum J Landscaping
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'nav-link relative text-sm font-medium transition-colors hover:text-green-600 py-1',
            currentPath === link.href ? 'nav-link--active text-green-700' : 'text-green-900',
          ]}
          aria-current={currentPath === link.href ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
      <Button href="/contact/" size="sm">Get a Free Quote</Button>
    </div>

    <!-- Mobile Menu Button (animated hamburger → X) -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-green-800 relative w-10 h-10 flex items-center justify-center"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <div class="hamburger-lines w-6 h-5 relative flex flex-col justify-between">
        <span class="hamburger-line block h-[2px] w-full bg-green-800 rounded-full origin-left"></span>
        <span class="hamburger-line block h-[2px] w-4 bg-green-800 rounded-full"></span>
        <span class="hamburger-line block h-[2px] w-5 bg-green-800 rounded-full origin-left"></span>
      </div>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="mobile-menu md:hidden fixed inset-0 top-16 bg-white z-50 px-6 pt-8 pb-6 flex flex-col" role="navigation" aria-label="Mobile navigation">
    <div class="flex flex-col gap-1 flex-1">
      {navLinks.map((link, i) => (
        <a
          href={link.href}
          class:list={[
            'mobile-menu-link block py-4 text-lg font-medium border-b border-gray-100 transition-colors',
            currentPath === link.href ? 'text-green-700' : 'text-green-900 hover:text-green-600',
          ]}
          style={`--delay: ${i * 60}ms`}
          aria-current={currentPath === link.href ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </div>
    <div class="mobile-menu-link mt-auto pt-6" style={`--delay: ${navLinks.length * 60}ms`}>
      <Button href="/contact/" size="lg" fullWidth>Get a Free Quote</Button>
    </div>
  </div>
</header>

<script>
  // Measure header height and set CSS variable for hero sizing
  const header = document.querySelector('header');
  if (header) {
    document.documentElement.style.setProperty('--header-height', header.offsetHeight + 'px');
  }

  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    btn.classList.toggle('is-active');
    menu?.classList.toggle('is-open');
    document.body.classList.toggle('overflow-hidden');
  });
</script>
