---
interface Props {
  text: string;
  variant?: 'dark' | 'light';
}

const { text, variant = 'dark' } = Astro.props;

const variants: Record<string, string> = {
  dark: 'bg-green-800/90 text-white',
  light: 'bg-green-100 text-green-800',
};
---

<span class:list={['text-xs font-semibold px-3 py-1 rounded-full', variants[variant]]}>
  {text}
</span>
