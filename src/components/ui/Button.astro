---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit';
  class?: string;
  fullWidth?: boolean;
  [key: string]: any;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type,
  class: className = '',
  fullWidth = false,
  ...attrs
} = Astro.props;

const base = 'inline-flex items-center justify-center font-semibold rounded-lg text-center transition-all duration-200 ease-out';

const variants: Record<string, string> = {
  primary: 'bg-green-700 text-white hover:bg-green-600 hover:shadow-lg hover:shadow-green-700/20 active:scale-[0.98]',
  secondary: 'bg-white text-green-800 hover:bg-green-50 hover:shadow-lg active:scale-[0.98]',
  outline: 'border-2 border-white text-white hover:bg-white/10 active:scale-[0.98]',
  ghost: 'text-green-700 hover:text-green-600 underline underline-offset-4 decoration-green-700/30 hover:decoration-green-600/60',
};

const sizes: Record<string, string> = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-sm',
  lg: 'px-8 py-4 text-base',
};

const classes = [base, variants[variant], sizes[size], fullWidth && 'w-full', className].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={classes} {...attrs}>
    <slot />
  </a>
) : (
  <button type={type || 'button'} class={classes} {...attrs}>
    <slot />
  </button>
)}
