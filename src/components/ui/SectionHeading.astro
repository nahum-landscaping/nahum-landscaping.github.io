---
interface Props {
  id?: string;
  title: string;
  subtitle?: string;
  align?: 'center' | 'left';
}

const { id, title, subtitle, align = 'center' } = Astro.props;
---

<div class:list={['mb-8 fade-up', align === 'center' && 'md:text-center']}>
  <h2 id={id} class="text-3xl sm:text-4xl font-bold text-green-900 mb-3">
    {title}
  </h2>
  {subtitle && (
    <p class:list={['text-gray-600 text-lg', align === 'center' && 'md:max-w-2xl md:mx-auto']}>
      {subtitle}
    </p>
  )}
</div>
