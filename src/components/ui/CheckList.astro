---
interface Props {
  items: string[];
  size?: 'sm' | 'md';
}

const { items, size = 'sm' } = Astro.props;
---

<ul class="space-y-2">
  {items.map((item) => (
    <li class:list={['flex items-start gap-2 text-gray-700', size === 'sm' && 'text-sm']}>
      <svg class="h-5 w-5 text-green-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
      {item}
    </li>
  ))}
</ul>
