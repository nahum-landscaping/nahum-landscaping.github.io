---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 card-hover fade-up">
  <div class="text-4xl mb-4" aria-hidden="true">{icon}</div>
  <h3 class="text-lg font-bold text-green-800 mb-2">{title}</h3>
  <p class="text-gray-600 text-sm leading-relaxed">{description}</p>
</div>
