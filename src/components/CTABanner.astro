---
import { Button, PhoneButton } from './ui';

interface Props {
  heading?: string;
  text?: string;
}

const {
  heading = 'Need Help With Your Yard?',
  text = 'We\'ll come take a look and give you an honest estimate. No pressure, no commitment.',
} = Astro.props;
---

<section class="bg-green-800 py-12 sm:py-15" aria-label="Call to action">
  <div class="max-w-4xl mx-auto px-5 sm:px-6 lg:px-4 md:text-center fade-up">
    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-3">{heading}</h2>
    <p class="text-green-100 text-lg mb-8 md:max-w-2xl md:mx-auto">{text}</p>
    <div class="flex flex-col sm:flex-row gap-4 md:justify-center">
      <Button href="/contact/" variant="secondary" size="lg">Get a Free Quote</Button>
      <PhoneButton />
    </div>
  </div>
</section>
