---
import { Button, PhoneButton } from './ui';

interface Props {
  heading?: string;
  text?: string;
}

const {
  heading = 'Ready to Transform Your Yard?',
  text = 'Get a free, no-obligation estimate for your landscaping project. Serving Sanford, FL and surrounding areas.',
} = Astro.props;
---

<section class="bg-green-800 py-10 sm:py-15" aria-label="Call to action">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">{heading}</h2>
    <p class="text-green-100 text-lg mb-8 max-w-2xl mx-auto">{text}</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href="/contact/" variant="secondary" size="lg">Get a Free Quote</Button>
      <PhoneButton />
    </div>
  </div>
</section>
